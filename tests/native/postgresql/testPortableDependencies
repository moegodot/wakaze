#!/usr/bin/env dotnet

#:package Serilog
#:package Serilog.Sinks.Console

using System.Diagnostics;
using System.Runtime.CompilerServices;
using Serilog;

return await RunAsync(args);

static async Task<int> RunAsync(string[] args)
{
    using var log = new LoggerConfiguration()
        .WriteTo.Console()
        .CreateLogger();
    Log.Logger = log;

    try
    {
        ValidateArguments(args);

        var repositoryRoot = GetRepositoryRoot(GetScriptPath());
        await using var environment = await PostgresTestEnvironment.CreateAsync(repositoryRoot, "portable-dependencies");

        if (!OperatingSystem.IsMacOS())
        {
            Log.Information("Portable dependency audit is only applicable on macOS. Skipping.");
            return 0;
        }

        var postgresOutput = await CommandRunner.RunAsync(
            "otool",
            ["-L", Path.Combine(environment.InstallDirectory, "bin", "postgres")],
            environment.RootDirectory,
            captureOutput: true);
        var psqlOutput = await CommandRunner.RunAsync(
            "otool",
            ["-L", Path.Combine(environment.InstallDirectory, "bin", "psql")],
            environment.RootDirectory,
            captureOutput: true);
        var initdbOutput = await CommandRunner.RunAsync(
            "otool",
            ["-L", Path.Combine(environment.InstallDirectory, "bin", "initdb")],
            environment.RootDirectory,
            captureOutput: true);
        var libpqDependencies = await CommandRunner.RunAsync(
            "otool",
            ["-L", Path.Combine(environment.InstallDirectory, "lib", "libpq.5.dylib")],
            environment.RootDirectory,
            captureOutput: true);
        var libpqInstallName = await CommandRunner.RunAsync(
            "otool",
            ["-D", Path.Combine(environment.InstallDirectory, "lib", "libpq.5.dylib")],
            environment.RootDirectory,
            captureOutput: true);

        AssertNoForbiddenPaths(postgresOutput.StandardOutput, repositoryRoot, "postgres dependencies");
        AssertNoForbiddenPaths(psqlOutput.StandardOutput, repositoryRoot, "psql dependencies");
        AssertNoForbiddenPaths(initdbOutput.StandardOutput, repositoryRoot, "initdb dependencies");
        AssertNoForbiddenPaths(libpqDependencies.StandardOutput, repositoryRoot, "libpq dependencies");

        AssertContains(postgresOutput.StandardOutput, "@executable_path/../lib/libssl.3.dylib", "postgres dependency relocation");
        AssertContains(psqlOutput.StandardOutput, "@executable_path/../lib/libpq.5.dylib", "psql dependency relocation");
        AssertContains(initdbOutput.StandardOutput, "@executable_path/../lib/libpq.5.dylib", "initdb dependency relocation");
        AssertContains(libpqDependencies.StandardOutput, "@loader_path/libssl.3.dylib", "libpq dependency relocation");
        AssertContains(libpqInstallName.StandardOutput, "@loader_path/libpq.5.dylib", "libpq install name");

        Log.Information("Portable dependency audit passed.");
        return 0;
    }
    catch (UsageException ex)
    {
        Log.Error("Error: {Message}", ex.Message);
        return 1;
    }
    catch (Exception ex)
    {
        Log.Error(ex, "Portable dependency audit failed.");
        return 1;
    }
}

static void ValidateArguments(IReadOnlyList<string> args)
{
    if (args.Count == 0)
    {
        return;
    }

    throw new UsageException("testPortableDependencies does not accept arguments.");
}

static void AssertNoForbiddenPaths(string output, string repositoryRoot, string operation)
{
    if (output.Contains(repositoryRoot, StringComparison.Ordinal))
    {
        throw new InvalidOperationException($"'{operation}' still references the repository root '{repositoryRoot}'.");
    }

    if (output.Contains("/opt/homebrew/", StringComparison.Ordinal))
    {
        throw new InvalidOperationException($"'{operation}' still references a Homebrew absolute path.");
    }
}

static void AssertContains(string actual, string expectedSubstring, string operation)
{
    if (!actual.Contains(expectedSubstring, StringComparison.Ordinal))
    {
        throw new InvalidOperationException($"Expected '{operation}' to contain '{expectedSubstring}', but got '{actual.Trim()}'.");
    }
}

static string GetScriptPath([CallerFilePath] string path = "")
{
    return path;
}

static string GetRepositoryRoot(string scriptPath)
{
    var currentDirectory = Path.GetDirectoryName(scriptPath)
        ?? throw new InvalidOperationException("Unable to resolve the script directory.");

    while (true)
    {
        if (File.Exists(Path.Combine(currentDirectory, "wakaze.root")))
        {
            return currentDirectory;
        }

        var parentDirectory = Path.GetDirectoryName(currentDirectory);
        if (parentDirectory is null)
        {
            throw new InvalidOperationException($"Unable to locate 'wakaze.root' starting from '{scriptPath}'.");
        }

        currentDirectory = parentDirectory;
    }
}

static class CommandRunner
{
    public static async Task<CommandResult> RunAsync(
        string fileName,
        IReadOnlyList<string> arguments,
        string workingDirectory,
        bool captureOutput = false)
    {
        var startInfo = new ProcessStartInfo
        {
            FileName = fileName,
            WorkingDirectory = workingDirectory,
            RedirectStandardOutput = captureOutput,
            RedirectStandardError = captureOutput,
            UseShellExecute = false,
        };

        foreach (var argument in arguments)
        {
            startInfo.ArgumentList.Add(argument);
        }

        using var process = new Process { StartInfo = startInfo };
        process.Start();

        string standardOutput = string.Empty;
        string standardError = string.Empty;

        if (captureOutput)
        {
            standardOutput = await process.StandardOutput.ReadToEndAsync();
            standardError = await process.StandardError.ReadToEndAsync();
        }

        await process.WaitForExitAsync();

        if (process.ExitCode != 0)
        {
            throw new InvalidOperationException(
                $"Command '{fileName}' exited with code {process.ExitCode}.{Environment.NewLine}" +
                $"stdout:{Environment.NewLine}{standardOutput}{Environment.NewLine}" +
                $"stderr:{Environment.NewLine}{standardError}");
        }

        return new CommandResult(process.ExitCode, standardOutput, standardError);
    }
}

sealed class PostgresTestEnvironment : IAsyncDisposable
{
    private PostgresTestEnvironment(string rootDirectory, string installDirectory)
    {
        RootDirectory = rootDirectory;
        InstallDirectory = installDirectory;
    }

    public string RootDirectory { get; }
    public string InstallDirectory { get; }

    public static async Task<PostgresTestEnvironment> CreateAsync(string repositoryRoot, string scenarioName)
    {
        var sourceInstallDirectory = Path.Combine(repositoryRoot, "vendors", "install", "postgresql");
        if (!Directory.Exists(sourceInstallDirectory))
        {
            throw new InvalidOperationException($"PostgreSQL install directory was not found at '{sourceInstallDirectory}'.");
        }

        var temporaryBaseDirectory = OperatingSystem.IsMacOS() ? "/tmp" : Path.GetTempPath();
        var rootDirectory = Path.Combine(temporaryBaseDirectory, $"wakaze-pg-{Guid.NewGuid():N}");
        var installDirectory = Path.Combine(rootDirectory, "postgresql");

        Directory.CreateDirectory(rootDirectory);
        await CommandRunner.RunAsync("/bin/cp", ["-R", sourceInstallDirectory, installDirectory], repositoryRoot);

        return new PostgresTestEnvironment(rootDirectory, installDirectory);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await CommandRunner.RunAsync("/bin/rm", ["-rf", RootDirectory], "/");
        }
        catch (Exception ex)
        {
            Log.Warning(ex, "Failed to delete temporary PostgreSQL test directory '{RootDirectory}'.", RootDirectory);
        }
    }
}

sealed class UsageException(string message) : Exception(message);

sealed record CommandResult(int ExitCode, string StandardOutput, string StandardError);
