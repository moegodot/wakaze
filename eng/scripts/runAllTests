#!/usr/bin/env dotnet

#:package Serilog
#:package Serilog.Sinks.Console

using System.Diagnostics;
using System.Runtime.CompilerServices;
using Serilog;

return await RunAsync(args);

static async Task<int> RunAsync(string[] forwardedArguments)
{
    using var log = new LoggerConfiguration()
        .WriteTo.Console()
        .CreateLogger();
    Log.Logger = log;

    try
    {
        var scriptPath = GetScriptPath();
        var repositoryRoot = GetRepositoryRoot(scriptPath);
        var nativeRunnerPath = Path.Combine(repositoryRoot, "tests", "native", "postgresql", "runAllTests");
        var managedRunnerPath = Path.Combine(repositoryRoot, "eng", "scripts", "runManagedTests");

        ValidateScriptExists(nativeRunnerPath, "native PostgreSQL test runner");
        ValidateScriptExists(managedRunnerPath, "managed test runner");

        Log.Information("==> Running native PostgreSQL tests");
        var exitCode = await RunDotnetFileScriptAsync(nativeRunnerPath, repositoryRoot, []);
        if (exitCode != 0)
        {
            Log.Error("<== Native PostgreSQL tests failed (exit code {ExitCode})", exitCode);
            return exitCode;
        }

        Log.Information("<== Native PostgreSQL tests passed");

        Log.Information("==> Running managed tests");
        exitCode = await RunDotnetFileScriptAsync(managedRunnerPath, repositoryRoot, forwardedArguments);
        if (exitCode != 0)
        {
            Log.Error("<== Managed tests failed (exit code {ExitCode})", exitCode);
            return exitCode;
        }

        Log.Information("<== Managed tests passed");
        Log.Information("All tests passed.");
        return 0;
    }
    catch (Exception ex)
    {
        Log.Error(ex, "runAllTests failed.");
        return 1;
    }
}

static async Task<int> RunDotnetFileScriptAsync(
    string scriptPath,
    string workingDirectory,
    IReadOnlyList<string> forwardedArguments)
{
    using var process = CreateDotnetFileScriptProcess(scriptPath, workingDirectory, forwardedArguments);
    if (!process.Start())
    {
        throw new InvalidOperationException($"Failed to start '{scriptPath}'.");
    }

    await process.WaitForExitAsync();
    return process.ExitCode;
}

static Process CreateDotnetFileScriptProcess(
    string scriptPath,
    string workingDirectory,
    IReadOnlyList<string> forwardedArguments)
{
    var startInfo = new ProcessStartInfo("dotnet")
    {
        WorkingDirectory = workingDirectory,
        UseShellExecute = false,
        CreateNoWindow = true,
    };

    startInfo.ArgumentList.Add("run");
    startInfo.ArgumentList.Add("--file");
    startInfo.ArgumentList.Add(scriptPath);
    startInfo.ArgumentList.Add("--");

    foreach (var argument in forwardedArguments)
    {
        startInfo.ArgumentList.Add(argument);
    }

    return new Process
    {
        StartInfo = startInfo,
    };
}

static void ValidateScriptExists(string path, string description)
{
    if (!File.Exists(path))
    {
        throw new InvalidOperationException($"The {description} was not found at '{path}'.");
    }
}

static string GetScriptPath([CallerFilePath] string path = "")
{
    return path;
}

static string GetRepositoryRoot(string scriptPath)
{
    var currentDirectory = Path.GetDirectoryName(scriptPath)
        ?? throw new InvalidOperationException("Unable to resolve the script directory.");

    while (true)
    {
        if (File.Exists(Path.Combine(currentDirectory, "wakaze.root")))
        {
            return currentDirectory;
        }

        var parentDirectory = Path.GetDirectoryName(currentDirectory);
        if (parentDirectory is null)
        {
            throw new InvalidOperationException($"Unable to locate 'wakaze.root' starting from '{scriptPath}'.");
        }

        currentDirectory = parentDirectory;
    }
}
