#!/usr/bin/env dotnet

#:package Serilog
#:package Serilog.Sinks.Console
#:project ../../src/managed/Kawayi.Wakaze.IO/Kawayi.Wakaze.IO.csproj
#:project ../../src/managed/Kawayi.Wakaze.Process/Kawayi.Wakaze.Process.csproj

using System.Runtime.CompilerServices;
using Kawayi.Wakaze.IO;
using Kawayi.Wakaze.Process;
using Serilog;

return await RunAsync(args);

static async Task<int> RunAsync(string[] forwardedArguments)
{
    using var log = new LoggerConfiguration()
        .WriteTo.Console()
        .CreateLogger();
    Log.Logger = log;

    var scriptPath = GetScriptPath();
    var repositoryRoot = RepositoryRootLocator.FindContainingDirectory(scriptPath, "wakaze.root");
    var managedTestsDirectory = Path.GetFullPath(Path.Combine(repositoryRoot, "tests", "managed"));

    var testProjects = Directory
        .EnumerateFiles(managedTestsDirectory, "*.Tests.csproj", SearchOption.AllDirectories)
        .OrderBy(static path => path, StringComparer.Ordinal)
        .ToArray();

    if (testProjects.Length == 0)
    {
        Log.Error($"No test projects matching '*.Tests.csproj' were found under '{managedTestsDirectory}'.");
        return 1;
    }

    var failedProjects = new List<string>();
    var hasTestSelectionArguments = HasTestSelectionArguments(forwardedArguments);

    foreach (var testProject in testProjects)
    {
        var displayPath = Path.GetRelativePath(repositoryRoot, testProject);
        Log.Information($"==> Running {displayPath}");

        var result = await ProcessCommandRunner.RunAsync(
            new ProcessCommandRequest(
                "dotnet",
                CreateArguments(testProject, forwardedArguments),
                repositoryRoot,
                CaptureOutput: false,
                EnvironmentVariables: null,
                ThrowOnNonZeroExit: false));

        if (result.ExitCode == 0)
        {
            Log.Information($"<== Passed {displayPath}");
            continue;
        }

        if (hasTestSelectionArguments && result.ExitCode == 8)
        {
            Log.Information($"<== Skipped {displayPath} (no matching tests)");
            continue;
        }

        Log.Error($"<== Failed {displayPath} (exit code {result.ExitCode})");
        failedProjects.Add(displayPath);
    }

    Log.Information($"Executed {testProjects.Length} test project(s).");

    if (failedProjects.Count == 0)
    {
        Log.Information("All managed test projects passed.");
        return 0;
    }

    Log.Error($"Managed test projects failed: {string.Join(", ", failedProjects)}");
    return 1;
}

static IReadOnlyList<string> CreateArguments(string testProject, IEnumerable<string> forwardedArguments)
{
    var arguments = new List<string>
    {
        "run",
        "--project",
        testProject,
        "--"
    };

    foreach (var argument in forwardedArguments)
    {
        arguments.Add(argument);
    }

    return arguments;
}

static string GetScriptPath([CallerFilePath] string path = "")
{
    return path;
}

static bool HasTestSelectionArguments(IEnumerable<string> forwardedArguments)
{
    foreach (var argument in forwardedArguments)
    {
        if (argument is "--treenode-filter" or "--filter-uid")
        {
            return true;
        }

        if (argument.StartsWith("--treenode-filter=", StringComparison.Ordinal)
            || argument.StartsWith("--filter-uid=", StringComparison.Ordinal))
        {
            return true;
        }
    }

    return false;
}
